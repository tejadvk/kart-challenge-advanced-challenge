# API base URL - use demo API by default
VITE_API_URL=https://orderfoodonline.deno.dev/api

# API key for placing orders
VITE_API_KEY=apitest

# Admin API key for /admin/* (products, inventory)
VITE_ADMIN_API_KEY=admin

# --- Local backend (go run ./cmd/api, default port 8080) ---
# VITE_API_URL=http://localhost:8080

# --- Docker (backend exposed on 8081) ---
# VITE_API_URL=http://localhost:8081
